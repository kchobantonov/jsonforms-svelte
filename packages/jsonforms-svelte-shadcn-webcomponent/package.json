{
  "name": "@chobantonov/jsonforms-svelte-shadcn-webcomponent",
  "version": "1.0.1",
  "description": "Shadcn-based JSONForms Svelte Web Component",
  "author": "Krasimir Chobantonov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chobantonov/jsonforms-svelte.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest --run"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/jsonforms-svelte-shadcn.js",
  "types": "./src/lib/index.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./dist/jsonforms-svelte-shadcn.js"
    }
  },
  "dependencies": {
    "@chobantonov/jsonforms-svelte": "workspace:*",
    "@chobantonov/jsonforms-svelte-extended": "workspace:*",
    "@chobantonov/jsonforms-svelte-shadcn": "workspace:*",
    "@chobantonov/jsonforms-svelte-shadcn-extended": "workspace:*",
    "@jsonforms/core": "catalog:",
    "@lucide/svelte": "^0.542.0",
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-i18n": "^4.2.0",
    "ajv-keywords": "^5.1.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.10.6",
    "lodash": "^4.17.21",
    "maska": "^3.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@lucide/svelte": "^0.542.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "4.2.1",
    "@types/lodash": "^4.14.172",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.17",
    "shadcn-svelte": "^1.4.2",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
