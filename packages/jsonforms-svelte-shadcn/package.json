{
  "name": "@chobantonov/jsonforms-svelte-shadcn",
  "version": "1.0.1",
  "description": "Shadcn-styled JSONForms Svelte 5 components",
  "author": "Krasimir Chobantonov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chobantonov/jsonforms-svelte.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "npm run check && vite build && npm run prepack",
    "watch": "svelte-kit sync && svelte-package --watch",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint --pack false",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest --run"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@chobantonov/jsonforms-svelte": "workspace:*",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/svelte": "^1.1.4",
    "@internationalized/date": "^3.12.0",
    "@jsonforms/core": "catalog:",
    "@lucide/svelte": "^0.542.0",
    "@tabler/icons-svelte": "^3.44.0",
    "ajv": "^8.20.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.10.6",
    "lodash": "^4.17.21",
    "maska": "^3.2.0",
    "phosphor-svelte": "^3.1.0",
    "remixicon-svelte": "^0.0.5",
    "svelte": "^5.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@chobantonov/jsonforms-svelte": "workspace:*",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/svelte": "^1.1.4",
    "@internationalized/date": "^3.12.0",
    "@jsonforms/core": "catalog:",
    "@lucide/svelte": "^0.542.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tabler/icons-svelte": "^3.44.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/lodash": "^4.14.172",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "ajv": "^8.20.0",
    "bits-ui": "^2.16.3",
    "dayjs": "^1.10.6",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "lodash": "^4.17.21",
    "maska": "^3.2.0",
    "phosphor-svelte": "^3.1.0",
    "playwright": "^1.58.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.17",
    "remixicon-svelte": "^0.0.5",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-svelte": "^2.0.2"
  }
}
